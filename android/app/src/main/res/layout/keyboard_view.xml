<?xml version="1.0" encoding="utf-8"?>
<!-- Compact "credential-only" keyboard used by KeepassImeService. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#374151"
    android:padding="8dp">

    <TextView
        android:id="@+id/kb_entry_label"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="8dp"
        android:paddingVertical="6dp"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:maxLines="1"
        android:ellipsize="end"
        android:text="@string/kb_no_entry" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="4dp">

        <Button
            android:id="@+id/kb_username"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:text="@string/kb_username" />

        <Button
            android:id="@+id/kb_password"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:text="@string/kb_password" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="4dp">

        <Button
            android:id="@+id/kb_open_app"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:textColor="#FFFFFF"
            android:background="@android:color/transparent"
            android:text="@string/kb_open_app" />

        <Button
            android:id="@+id/kb_switch"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:textColor="#FFFFFF"
            android:background="@android:color/transparent"
            android:text="@string/kb_switch" />
    </LinearLayout>
</LinearLayout>
